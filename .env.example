# =============================================================================
# CHATSPHERE — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development               # development | production | test
CLIENT_URL=http://localhost:3000   # Comma-separated for multiple origins
HTTPS=false                        # Set true + SSL certs for HTTPS

# ─── MongoDB ───────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/chatapp?retryWrites=true&w=majority

# ─── JWT Secrets (CRITICAL: generate strong random values) ───────────────────
# Run `node server/scripts/generate-secrets.js` to create secure secrets
JWT_SECRET=generate-a-random-64-char-hex-secret-here-not-this-placeholder
JWT_REFRESH_SECRET=generate-another-random-64-char-hex-secret-here

# ─── Email (Choose one provider) ──────────────────────────────────────────────
# Option A: Resend (Recommended — https://resend.com)
# RESEND_API_KEY=re_xxxxx
# RESEND_FROM=ChatSphere <noreply@yourdomain.com>

# Option B: SendGrid (https://sendgrid.com)
# SENDGRID_API_KEY=SG.xxxxx

# Option C: SMTP (Any provider)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your@email.com
# SMTP_PASS=your-password

# ─── File Uploads (Cloudinary — https://cloudinary.com) ───────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── Email Verification ───────────────────────────────────────────────────────
REQUIRE_EMAIL_VERIFICATION=true    # Set false to disable email verification gate
DEV_AUTO_VERIFY=true               # Auto-verify users in dev (when no real email provider)

# ─── SSL/HTTPS ────────────────────────────────────────────────────────────────
# SSL_PATH=./ssl                    # Path to SSL certificate directory
                                    # Required files: privkey.pem, cert.pem, chain.pem

# ─── Security (Optional overrides) ──────────────────────────────────────────
# CSRF_SECRET=                      # Auto-generated if not set
