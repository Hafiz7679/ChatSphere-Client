# ChatSphere Client Environment Variables
# Copy this to .env for local development:
#   cp .env.example .env

# Local development — server runs on port 5000
VITE_API_URL=http://localhost:5000/api
VITE_SOCKET_URL=http://localhost:5000

# Production (set these in Vercel Dashboard → Project Settings → Environment Variables)
# VITE_API_URL=https://your-server-domain.com/api
# VITE_SOCKET_URL=https://your-server-domain.com
